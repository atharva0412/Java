public class Main
{
	public static void main(String[] args) {
	    int[] arr = {5, 2, 7, -1, 6};
	    
	    int pos = 0;
	    int neg = 0;
	    int zero = 0;
	    
	   for(int i = 0; i < arr.length; i++) {
	       if (arr[i] < 0) neg++;
	       else if (arr[i] > 0) pos++;
	       else zero++;
	   }
	   System.out.println("Positive: " + pos);
       System.out.println("Negative: " + neg);
       System.out.println("Zero: " + zero);
	}
}
